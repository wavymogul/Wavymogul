# Password gate for the /admin dashboard (change before deploying!)
ADMIN_PASSWORD=somingle-admin

# Optional: absolute path for the SQLite database file.
# Defaults to ./data/somingle.db when unset.
# SOMINGLE_DB_PATH=/var/data/somingle.db

# Public site URL, used for SEO metadata + sitemap.
NEXT_PUBLIC_SITE_URL=https://somingle.io
