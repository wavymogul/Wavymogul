# Login for the /admin dashboard. Defaults to admin / Miller31! if unset.
# Override these in your host's environment variables for better security.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Miller31!

# Public site URL, used for SEO metadata + sitemap.
NEXT_PUBLIC_SITE_URL=https://somingle.netlify.app

# Storage:
# - On Netlify, survey/waitlist data is persisted to Netlify Blobs automatically
#   (no configuration or credentials required).
# - For local `next dev`, data falls back to JSON files under ./data.
#   Optionally override that location:
# SOMINGLE_DB_PATH=/absolute/path/to/data/store.json
